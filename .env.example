# Copy to Railway Variables (or local .env for npm run alerts)

# Telegram — phone notifications jab web band ho
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Web Push — phone notifications without Telegram/VPN (works when browser closed).
# Generate once with:  npm run gen-vapid
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
# Optional contact (used in VAPID JWT). Defaults to mailto:alerts@scalping.local
# WEB_PUSH_CONTACT=mailto:you@example.com

# auto | 1 | 0 — Railway pe Telegram set ho to auto-start
ENABLE_ALERT_WORKER=auto

# Optional poll interval (ms)
# ALERT_TICK_MS=2500
