{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["src"],
  "exclude": [
    "daemon",
    "src/calibration/db.ts",
    "src/calibration/signalStore.ts",
    "src/calibration/logSignal.ts",
    "src/calibration/resolveOutcomes.ts",
    "src/calibration/recalibrate.ts",
    "src/calibration/realizedR.ts",
    "src/calibration/index.ts"
  ]
}
